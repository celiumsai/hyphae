{
  "name": "@celiums/hyphae-integrations",
  "version": "0.1.0-alpha.1",
  "description": "Optional Astro, Next, and Vite adapters for Hyphae v1",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./vite/client": {
      "types": "./dist/vite-client.d.ts",
      "import": "./dist/vite-client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "conformance": "node conformance/run.mjs",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "@celiums/hyphae": "0.1.0-alpha.1",
    "astro": ">=5 <8",
    "next": ">=15 <17",
    "vite": ">=6 <9"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@celiums/hyphae": "file:../../sdks/typescript",
    "@types/node": "24.10.1",
    "astro": "7.0.9",
    "typescript": "5.9.3",
    "vite": "8.1.4"
  }
}
