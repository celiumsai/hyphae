{
  "name": "@celiums/hyphae",
  "version": "0.2.0",
  "description": "Bounded TypeScript client for the public Hyphae v1 API",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "conformance": "npm run build && node conformance/run.mjs"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
