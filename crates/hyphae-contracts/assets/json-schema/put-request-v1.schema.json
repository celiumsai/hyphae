{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PutRequestV1",
  "description": "Atomic durable put batch.",
  "type": "object",
  "properties": {
    "records": {
      "description": "Nonempty atomic record batch.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/RecordV1"
      }
    },
    "transaction_id": {
      "description": "Optional UUID idempotency key; a `UUIDv7` is generated when absent.",
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    }
  },
  "additionalProperties": false,
  "required": [
    "records"
  ],
  "$defs": {
    "RecordV1": {
      "description": "One structured record on the wire.",
      "type": "object",
      "properties": {
        "key_hex": {
          "description": "Nonempty binary key encoded as hexadecimal.",
          "type": "string"
        },
        "value": {
          "description": "Natural JSON structured value with the reserved bytes envelope."
        }
      },
      "additionalProperties": false,
      "required": [
        "key_hex",
        "value"
      ]
    }
  }
}
