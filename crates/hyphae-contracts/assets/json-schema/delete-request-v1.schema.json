{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeleteRequestV1",
  "description": "Atomic durable delete batch.",
  "type": "object",
  "properties": {
    "keys_hex": {
      "description": "Nonempty binary keys encoded as hexadecimal.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "transaction_id": {
      "description": "Optional UUID idempotency key; a `UUIDv7` is generated when absent.",
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    }
  },
  "additionalProperties": false,
  "required": [
    "keys_hex"
  ]
}
